{
    "name": "wonder-image/new-site",
    "type": "project",
    "description": "The skeleton application for the Wonder Image framework.",
    "keywords": [
        "wonder-image",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "wonder-image/app": "dev-main"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "custom/class/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@composer dump-autoload",
            "php forge config"
        ],
        "post-update-cmd": [
            "@composer dump-autoload",
            "php forge config"
        ]
    },
    "config": {
        "platform": {
            "php": "8.2.30"
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
