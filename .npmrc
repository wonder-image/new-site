# Fallisci se i peer deps non sono soddisfatti (vs accettarli silenziosamente).
legacy-peer-deps=false

# npm rifiuta l'install se Node è sotto `engines.node` di un package
# (vs warning EBADENGINE che passa inosservato). Il package `wonder-image`
# ha `engines.node >= 20`, quindi con Node 16/18 si interrompe subito.
# Doppia difesa con `ensureNodeMinimumVersion(20)` di `forge config`.
engine-strict=true
